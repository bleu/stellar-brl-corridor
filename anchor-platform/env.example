# Bleu — Anchor Platform · example env (testnet).
# Copy to .env and fill the [NEEDS] values. See https://developers.stellar.org/docs/category/anchor-platform.

# ---------- SEP toggles ----------
SEP1_ENABLED=true
SEP10_ENABLED=true
SEP12_ENABLED=true
SEP24_ENABLED=true
SEP31_ENABLED=true
SEP38_ENABLED=true

# ---------- Stellar network ----------
STELLAR_NETWORK_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_NETWORK_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_RPC_URL=https://soroban-testnet.stellar.org

# ---------- SEP-10 web auth ----------
SEP10_HOME_DOMAIN=[NEEDS: your-anchor-domain.example.com]
SEP10_SIGNING_SEED=[NEEDS: SEP-10 signing seed (testnet)]

# ---------- Platform API ----------
PLATFORM_API_BASE_URL=http://anchor-platform:8081
PLATFORM_SERVER_AUTH_TYPE=jwt
PLATFORM_SERVER_SECRET=[NEEDS: random secret >= 32 chars]

# ---------- Database ----------
DATA_TYPE=postgres
DATA_SERVER=postgres
DATA_DATABASE=anchor
DATA_USERNAME=anchor
DATA_PASSWORD=anchor

# ---------- Custody ----------
# Testnet: self-custody. Mainnet: switch to 'fireblocks' and provide credentials.
CUSTODY_TYPE=none
