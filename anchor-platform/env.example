# Bleu — Anchor Platform · example env (testnet).
# Copy to .env and fill the [NEEDS] values.
#
# Var names match Anchor Platform 4.x: each maps a dotted config key by
# uppercasing and replacing '.' with '_'  (e.g. secret.data.username ->
# SECRET_DATA_USERNAME). Verified against the AP 4.3.0 image's default profile.
# See https://developers.stellar.org/docs/category/anchor-platform.

# ---------- SEP toggles ----------
SEP1_ENABLED=true
SEP10_ENABLED=true
SEP12_ENABLED=true
SEP24_ENABLED=true
SEP31_ENABLED=true
SEP38_ENABLED=true

# ---------- Stellar network ----------
STELLAR_NETWORK_TYPE=rpc
STELLAR_NETWORK_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_NETWORK_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# ---------- SEP-1: serve our stellar.toml from file ----------
SEP1_TOML_TYPE=file
SEP1_TOML_VALUE=/home/anchorplatform/config/sep1-stellar.toml

# ---------- SEP-10 web auth ----------
SEP10_HOME_DOMAINS=anchor.bleu.builders
SEP10_WEB_AUTH_DOMAIN=anchor.bleu.builders
SECRET_SEP10_SIGNING_SEED=[NEEDS: SEP-10 signing seed (testnet) — secret S... for the SIGNING_KEY in stellar.toml]
SECRET_SEP10_JWT_SECRET=[NEEDS: random secret >= 32 chars]

# ---------- Platform / callback API ----------
PLATFORM_API_BASE_URL=http://anchor-platform:8085
SECRET_PLATFORM_API_AUTH_SECRET=[NEEDS: random secret >= 32 chars]
SECRET_CALLBACK_API_AUTH_SECRET=[NEEDS: random secret >= 32 chars]

# ---------- Database ----------
DATA_TYPE=postgres
DATA_SERVER=postgres:5432
DATA_DATABASE=anchor
DATA_FLYWAY_ENABLED=true
SECRET_DATA_USERNAME=anchor
SECRET_DATA_PASSWORD=anchor

# ---------- Assets / SEP-38 quote config ----------
# Corridor: sell=USDC, buy=iso4217:BRL via PIX, country=BR.
ASSETS_TYPE=file
ASSETS_VALUE=/home/anchorplatform/config/sep38-assets.yaml

# SEP-31 deposit-info generator (AP 4.x enum: self | none). Firm quotes for
# this corridor are enforced per-asset via sep31.quotes_required in
# config/sep38-assets.yaml.
SEP31_DEPOSIT_INFO_GENERATOR_TYPE=self

# ---------- Custody ----------
# Testnet: self-custody. Mainnet: switch to 'fireblocks' and provide credentials.
CUSTODY_TYPE=none
