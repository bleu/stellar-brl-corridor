title: Bleu · Card Authorization — Hybrid Architecture · Production Vault Design (C4 L3 Sequence) {
  near: top-center
  style.font-size: 28
  style.bold: true
}

# NOTE: This sequence depicts the PRODUCTION card-collateral vault target
# (SmartAccount / webauthn / spending-limit policy / USDC settlement, CAP-21/23).
# The shipped testnet PoC (`contracts/card-collateral-poc`) implements only the
# admin-gated reserve/settle/release state machine + shortfall accounting,
# composing OZ `pausable` + `access_control`; it does not call USDC or do_check_auth.

shape: sequence_diagram

cardholder: Cardholder
merchant: Merchant POS
network: Card Network\n(Visa / Mastercard)
issuer: Issuer / BIN Sponsor\n(Monavate-pattern EMI)
adapter: Card Issuer Adapter\n(Bleu · offchain)
vault: Card-Collateral Vault\n(Soroban · production vault design)
usdc: USDC SAC\n(Stellar Mainnet)

# 1. Swipe — offchain card rails
cardholder -> merchant: "1. swipe / tap\n€50 purchase"
merchant -> network: "2. authorization request"
network -> issuer: "3. auth req\nPAN / amount / MCC"

# 2. Issuer webhooks to Bleu
issuer -> adapter: "4. POST /auth webhook\n{card_bin, amount_usd,\nmerchant, mcc}"

# 3. Bleu reserves collateral onchain
adapter -> vault: "5. invoke reserve(card_bin,\namount, expires_at)"
vault -> vault: "6. SmartAccount.do_check_auth\nwebauthn / ed25519"
vault -> vault: "7. SpendingLimit check\nrolling window"
vault -> vault: "8. #[when_not_paused] guard"
vault -> usdc: "9. transfer_from(allowance)"
usdc -> vault: "10. SEP-41 transfer event"
vault -> vault: "11. Lock(id) Persistent entry"
vault -> adapter: "12. reserve_ok — emit\n(collateral_locked, card_bin)"

# 4. Adapter returns auth decision
adapter -> issuer: "13. 200 approve\n(auth_id, reserved_amount)"
issuer -> network: "14. approved"
network -> merchant: "15. approval code"
merchant -> cardholder: "16. ✓ receipt"

# 5. Capture (async clearing)
network -> issuer: "17. clearing batch"
issuer -> adapter: "18. POST /capture webhook\n(auth_id, final_amount)"
adapter -> vault: "19. invoke settle(auth_id,\nfinal_amount)"
vault -> vault: "20. CAP-21 minSeqAge\ncool-down enforced"
vault -> usdc: "21. transfer → issuer\nsettlement address"
vault -> adapter: "22. emit (card_settle, auth_id,\nfinal_amount)\n+ (shortfall) if breached"

# 6. Refund or unused-auth auto-return
network -> issuer: "23. refund / expire"
issuer -> adapter: "24. POST /refund OR\n(no capture before expiry)"
adapter -> vault: "25. invoke release(auth_id)"
vault -> vault: "26. CAP-23 Claimable Balance\nAnd(Claimant(cardholder),\nAbsBefore(expires_at))"
vault -> adapter: "27. emit (collateral_released)"
