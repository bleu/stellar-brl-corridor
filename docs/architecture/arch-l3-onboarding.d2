title: Bleu · CAP-0033 Sponsor-Sandwich Onboarding (C4 L3 Sequence) {
  near: top-center
  style.font-size: 28
  style.bold: true
}

shape: sequence_diagram

enterprise: Enterprise User\n(non-crypto · zero XLM)
fintech: Fintech UI
api: Bleu API Gateway
orch: Orchestrator Service
signer: Sponsor Signer\n(hardware wallet / Fireblocks)
rpc: Stellar RPC
core: Stellar Core\n(Mainnet)

# 1. Onboarding request
enterprise -> fintech: "1. sign up\nbusiness email · CPF/CNPJ"
fintech -> api: "2. POST /accounts/onboard\n(KYC pre-verified via SEP-12)"
api -> orch: "3. orchestrate onboarding"

# 2. Build atomic sponsor sandwich
orch -> orch: "4. generate sponsored keypair\n(ephemeral; delivered to wallet\nvia BYO wallet interop)"
orch -> orch: "5. build tx with ordered ops:\nBegin → CreateAccount →\nChangeTrust(USDC) →\nChangeTrust(BRL) → End"

# 3. Dual signature — mutual consent
orch -> signer: "6. sign as sponsor\n(ops Begin/End require sponsor auth)"
signer -> orch: "7. sig_sponsor"
orch -> orch: "8. sign as sponsored\n(CreateAccount + ChangeTrusts\nrequire sponsored auth)"

# Architectural constraint
orch -> orch: "⚠ Soroban contracts CANNOT\ninteract with sponsorships —\nsandwich runs in classic-tx layer\naround any contract calls"

# 4. Submit atomic tx
orch -> rpc: "9. sendTransaction(sandwich_tx)"
rpc -> core: "10. submit to ledger"
core -> core: "11. validate sponsor reserve liquidity"
core -> core: "12. AccountEntryExtensionV2.\nnumSponsored++"
core -> core: "13. verify mutual-consent\nop balance"
core -> rpc: "14. ledger close — tx success"
rpc -> orch: "15. tx_hash + ledger_sequence"

# 5. Surface to user
orch -> api: "16. account ready\n(pk, sponsored_reserves ≈ 2 XLM)"
api -> fintech: "17. 200 OK\ntrustlines: USDC, BRL"
fintech -> enterprise: "18. account ready\ncan receive USDC + BRL\n(zero XLM required)"

# 6. Revocation / transfer paths (documented for later lifecycle)
orch -> orch: "↻ if user self-funds →\nRevokeSponsorshipOp\nreturns reserves to Bleu"
orch -> orch: "↻ if Bleu off-boards →\nsponsorship transferable to\nreplacement sponsor (no user action)"
orch -> orch: "per-user Bleu cost:\n~2 XLM (~USD 0.20) until revoked"
